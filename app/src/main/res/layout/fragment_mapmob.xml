<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:mapbox="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/common_google_signin_btn_text_dark_default"
    tools:context="UI.MapmobFragment">

    <com.mapbox.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        mapbox:mapbox_cameraBearing="-17.6"
        mapbox:mapbox_cameraTargetLat="32.941484"
        mapbox:mapbox_cameraTargetLng="35.795603"
        mapbox:mapbox_cameraZoom="16"
        />

    <TextView
        android:layout_gravity="center"
        android:id="@+id/tvLoadLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/load_my_location"
        android:textColor="@color/black"
        android:background="@color/white"
        android:visibility="gone"
        />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fbRefresh1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="36dp"

        android:layout_marginBottom="36dp"
        android:contentDescription="sss"
        android:src="@mipmap/ic_move_my_location"
        android:visibility="visible"
        app:backgroundTint="@color/turquoise_blue"
        app:layout_constraintBottom_toBottomOf="parent" />



</FrameLayout>